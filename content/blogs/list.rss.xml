<!-- layouts/_default/list.rss.xml -->
<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Site.Home.RelPermalink }}</link>
    <description>{{ .Site.Params.description }}</description>
    <lastBuildDate>{{ .Site.LastChange.Format "Mon, 2 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <generator>Hugo {{ .Hugo.Version }}</generator>
    {{ range .Site.RegularPages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <description>{{ .Summary }}</description>
      <pubDate>{{ .Date.Format "Mon, 2 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <author>{{ .Site.Author.name }} ({{ .Site.Author.email }})</author>
    </item>
    {{ end }}
  </channel>
</rss>